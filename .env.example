# Copy to .env — used by Docker Compose variable substitution
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite-preview

TX_INTERVAL_SEC=5
SIMULATOR_KAFKA_WAIT_SEC=120
SIMULATOR_KAFKA_RETRY_SEC=2

# ML: USE_EMBEDDING_MODEL=1 → MiniLM embeddings + LR; USE_ENSEMBLE=1 → stacked ensemble (slow)
USE_EMBEDDING_MODEL=0
USE_ENSEMBLE=0
TRAIN_ON_BOOT=1

# Auto-retrain after N corrections (PostgreSQL + JSONL)
RETRAIN_CORRECTION_THRESHOLD=50
RETRAIN_MAX_AGE_HOURS=24
MODEL_PROMOTION_MIN_ACC=0.80

# PostgreSQL (used by docker-compose and clients)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=expense
POSTGRES_USER=expense
POSTGRES_PASSWORD=expense
# Container-internal DB URL (service name = postgres)
DATABASE_URL_DOCKER=postgresql://expense:expense@postgres:5432/expense
# Host DB URL (for pgAdmin / local scripts)
DATABASE_URL=postgresql://expense:expense@localhost:5432/expense

# MLflow (optional for local runs, required for model tracking/registry)
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_ENABLE_REGISTRY=1
MLFLOW_MODEL_NAME=expense-categoriser
MLFLOW_RUNTIME_EXPERIMENT=expense-runtime
MLFLOW_RUNTIME_FLUSH_SEC=30
MLFLOW_RUNTIME_MIN_BATCH=25

# Local service routing (non-docker runs)
KAFKA_BOOTSTRAP_SERVERS=localhost:29092
ML_SERVICE_URL=http://localhost:8001
PARSER_SERVICE_URL=http://localhost:8002
GENAI_SERVICE_URL=http://localhost:8003
GATEWAY_KAFKA_WAIT_SEC=120
GATEWAY_KAFKA_RETRY_SEC=2
GATEWAY_KAFKA_AUTO_OFFSET_RESET=latest

# Parser uploads: batch classify (default) = chunked POST /classify_batch — fast.
# Set USE_CLASSIFY_BATCH=0 only to force legacy Kafka+Redis (USE_KAFKA_UPLOAD_PATH=1) or per-row HTTP.
USE_CLASSIFY_BATCH=0
# Max rows per /classify_batch request chunk (parser-service; visible progress between chunks)
CLASSIFY_BATCH_CHUNK=50
# Parser: 1 = Kafka+Redis per row when USE_CLASSIFY_BATCH=0
USE_KAFKA_UPLOAD_PATH=1

# OCR tuning (scanned PDFs)
OCR_MAX_PAGES=16
OCR_DPI=220
OCR_MIN_ROWS=2
# Optional on Windows if tesseract not on PATH:
# TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe

# Local observability only:
PROMETHEUS_CONFIG_FILE=/etc/prometheus/prometheus.yml
